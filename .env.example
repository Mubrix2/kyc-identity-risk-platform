# ── PostgreSQL ────────────────────────────────────────────────────────────────
# Local: docker compose provides a postgres service
# Schema applied via app/db/database.py on startup
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=kyc_platform
POSTGRES_USER=kyc_user
POSTGRES_PASSWORD=change_me

# ── Kafka (local WSL2 broker — same as Project 1) ──────────────────────────────
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_KYC_EVENTS_TOPIC=kyc-events
KAFKA_KYC_RESULTS_TOPIC=kyc-results
KAFKA_CONSUMER_GROUP=kyc-platform-group

# ── Risk Decision Thresholds ────────────────────────────────────────────────────
# risk_probability >= REJECT_THRESHOLD     → REJECT
# risk_probability >= REVIEW_THRESHOLD     → REVIEW
# else                                     → APPROVE
RISK_REVIEW_THRESHOLD=0.40
RISK_REJECT_THRESHOLD=0.75

# ── Sanctions Screening ──────────────────────────────────────────────────────────
# Fuzzy match score (0-100) above which a name is flagged as a possible
# sanctions match. Calibrated during Phase 2 data exploration.
SANCTIONS_MATCH_THRESHOLD=85

# ── OCR ────────────────────────────────────────────────────────────────────────
# Tesseract must be installed at the OS level (apt-get install tesseract-ocr)
TESSERACT_CMD=/usr/bin/tesseract

# ── App ────────────────────────────────────────────────────────────────────────
APP_ENV=development